generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum SantriStatus {
  AKTIF
  NONAKTIF
  LULUS
  KELUAR
}

enum Gender {
  L
  P
}

enum KomponenTipe {
  BULANAN
  INSIDENTAL
  SANTRI_BARU
}

enum DiskonEligibilityRule {
  NONE
  SIBLING_FAMILY
  SANTRI_YATIM
  SANTRI_KELUARGA_NDALEM
}

enum RuleCakupanType {
  GLOBAL
  KELAS
  GENDER
  SANTRI
}

enum RuleTagihanStatus {
  DRAFT
  PUBLISHED
}

enum TargetTagihanType {
  SEMUA_SANTRI
  GENDER
  KELAS
  SPESIFIK_SANTRI
  SANTRI_BARU
}

enum TagihanMasterStatus {
  SCHEDULED
  ACTIVE
  ENDED
  INACTIVE
}

enum TagihanStatus {
  DRAFT
  TERBIT
  SEBAGIAN
  LUNAS
  BATAL
}

enum PaymentMethod {
  TUNAI
  TRANSFER
}

enum KwitansiTemplate {
  RINGKAS
  LENGKAP
}

enum TagihanPicMode {
  GLOBAL
  BY_GENDER
  BY_KELAS
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  active       Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tagihanMasterPicGlobal TagihanMaster[] @relation("TagihanMasterPicGlobal")
  tagihanMasterPicPutra  TagihanMaster[] @relation("TagihanMasterPicPutra")
  tagihanMasterPicPutri  TagihanMaster[] @relation("TagihanMasterPicPutri")
  tagihanMasterPicKelas  TagihanMasterPicKelas[]
  tagihanPic             Tagihan[]       @relation("TagihanPicUser")
}

model Kelas {
  id        String   @id @default(cuid())
  nama      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  santri    Santri[]
  ruleTagihan RuleTagihan[]
  tagihanMasterDetail TagihanMasterDetail[]
  tagihanMasterPicKelas TagihanMasterPicKelas[]
}

model Keluarga {
  id               String   @id @default(cuid())
  kodeKeluarga     String   @unique
  namaKepalaFamily String?
  keterangan       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  santri           Santri[]
}

model Santri {
  id             String       @id @default(cuid())
  nis            String       @unique
  nama           String
  status         SantriStatus @default(AKTIF)
  gender         Gender
  kelasId        String
  keluargaId     String?
  yatim          Boolean      @default(false)
  keluargaNdalem Boolean      @default(false)
  tanggalMasuk   DateTime?
  tanggalKeluar DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  kelas          Kelas        @relation(fields: [kelasId], references: [id])
  keluarga       Keluarga?    @relation(fields: [keluargaId], references: [id])
  ruleTagihan    RuleTagihan[]
  tagihan        Tagihan[]
  tagihanMasterDetail TagihanMasterDetail[]
}

model KomponenTagihan {
  id             String            @id @default(cuid())
  kode           String            @unique
  nama           String
  tipe           KomponenTipe
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  diskonKomponen DiskonKomponen[]
  ruleTagihan    RuleTagihan[]
  tagihanMaster  TagihanMaster[]
  tagihan        Tagihan[]
}

model DiskonKategori {
  id              String                @id @default(cuid())
  kode            String                @unique
  nama            String
  eligibilityRule DiskonEligibilityRule @default(NONE)
  siblingCountMin Int?
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  diskonKomponen  DiskonKomponen[]
}

model DiskonKomponen {
  id          String         @id @default(cuid())
  komponenId  String
  kategoriId  String
  persentase  Float
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  komponen    KomponenTagihan @relation(fields: [komponenId], references: [id])
  kategori    DiskonKategori  @relation(fields: [kategoriId], references: [id])

  @@unique([komponenId, kategoriId])
}

model RuleTagihan {
  id         String            @id @default(cuid())
  komponenId String
  nominal    Float
  cakupan    RuleCakupanType
  kelasId    String?
  gender     Gender?
  santriId   String?
  status     RuleTagihanStatus @default(DRAFT)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  komponen   KomponenTagihan   @relation(fields: [komponenId], references: [id])
  kelas      Kelas?            @relation(fields: [kelasId], references: [id])
  santri     Santri?           @relation(fields: [santriId], references: [id])
}

model TagihanMaster {
  id                   String              @id @default(cuid())
  komponenId           String
  namaTagihan          String?
  targetType           TargetTagihanType
  status               TagihanMasterStatus @default(SCHEDULED)
  autoGenerateEnabled  Boolean             @default(true)
  picMode              TagihanPicMode      @default(GLOBAL)
  picGlobalUserId      String?
  picPutraUserId       String?
  picPutriUserId       String?
  nominalGlobal        Float?
  startBulan           Int?
  startTahun           Int?
  endBulan             Int?
  endTahun             Int?
  lastGeneratedPeriod  String?
  jatuhTempoHari       Int?
  tanggalTerbit        DateTime?
  jatuhTempo           DateTime
  keterangan           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  komponen             KomponenTagihan      @relation(fields: [komponenId], references: [id])
  picGlobalUser        User?               @relation("TagihanMasterPicGlobal", fields: [picGlobalUserId], references: [id])
  picPutraUser         User?               @relation("TagihanMasterPicPutra", fields: [picPutraUserId], references: [id])
  picPutriUser         User?               @relation("TagihanMasterPicPutri", fields: [picPutriUserId], references: [id])
  details         TagihanMasterDetail[]
  picKelas        TagihanMasterPicKelas[]
  tagihan         Tagihan[]
  generateLogs    TagihanGenerateLog[]
}

model TagihanMasterPicKelas {
  id          String       @id @default(cuid())
  masterId    String
  kelasId     String
  picUserId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  master      TagihanMaster @relation(fields: [masterId], references: [id], onDelete: Cascade)
  kelas       Kelas         @relation(fields: [kelasId], references: [id])
  picUser     User?         @relation(fields: [picUserId], references: [id])

  @@unique([masterId, kelasId])
}

model TagihanMasterDetail {
  id          String       @id @default(cuid())
  masterId    String
  gender      Gender?
  kelasId     String?
  santriId    String?
  nominal     Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  master      TagihanMaster @relation(fields: [masterId], references: [id], onDelete: Cascade)
  kelas       Kelas?        @relation(fields: [kelasId], references: [id])
  santri      Santri?       @relation(fields: [santriId], references: [id])
}

model Tagihan {
  id            String       @id @default(cuid())
  masterId      String
  santriId      String
  komponenId    String
  periodeKey    String
  nominalAwal   Float        @default(0)
  nominalDiskon Float        @default(0)
  nominal       Float
  nominalTerbayar Float      @default(0)
  picUserId      String?
  jatuhTempo    DateTime
  status        TagihanStatus @default(TERBIT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  master        TagihanMaster @relation(fields: [masterId], references: [id])
  santri        Santri        @relation(fields: [santriId], references: [id])
  komponen      KomponenTagihan @relation(fields: [komponenId], references: [id])
  picUser       User?          @relation("TagihanPicUser", fields: [picUserId], references: [id])
  pembayaran    Pembayaran[]

  @@unique([santriId, komponenId, periodeKey])
}

model TagihanGenerateLog {
  id            String   @id @default(cuid())
  masterId      String
  periodeKey    String
  source        String
  totalTarget   Int
  generated     Int
  skipped       Int
  success       Boolean
  message       String?
  createdAt     DateTime @default(now())

  master        TagihanMaster @relation(fields: [masterId], references: [id], onDelete: Cascade)
}

model Pembayaran {
  id            String        @id @default(cuid())
  tagihanId     String
  tanggalBayar  DateTime      @default(now())
  nominal       Float
  metode        PaymentMethod
  referensi     String?
  adminUsername String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tagihan       Tagihan       @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  kwitansi      Kwitansi?
}

model Kwitansi {
  id            String           @id @default(cuid())
  nomor         String           @unique
  pembayaranId  String           @unique
  template      KwitansiTemplate @default(LENGKAP)
  adminUsername String
  logoUrl       String?
  stempelUrl    String?
  createdAt     DateTime         @default(now())

  pembayaran    Pembayaran       @relation(fields: [pembayaranId], references: [id], onDelete: Cascade)
}
